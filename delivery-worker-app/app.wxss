/**app.wxss**/

/* 全局样式 */
page {
  --primary-color: #1890ff;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --error-color: #f5222d;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --bg-gray: #f5f5f5;
  --border-color: #e8e8e8;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-gray);
  line-height: 1.6;
}

/* 容器 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-success {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #ffffff;
}

.btn-warning {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
  color: #ffffff;
}

.btn-error {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #ffffff;
}

.btn-disabled {
  background: #d9d9d9 !important;
  color: #999999 !important;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-success {
  background: #f6ffed;
  color: #52c41a;
}

.status-warning {
  background: #fffbe6;
  color: #faad14;
}

.status-error {
  background: #fff1f0;
  color: #ff4d4f;
}

.status-primary {
  background: #e6f7ff;
  color: #1890ff;
}

/* 数据展示 */
.data-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.data-item:last-child {
  border-bottom: none;
}

.data-label {
  color: var(--text-secondary);
  font-size: 28rpx;
  min-width: 160rpx;
}

.data-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 图标样式 */
.icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.icon-large {
  width: 80rpx;
  height: 80rpx;
}

/* 网格布局 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.list-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 40rpx;
}

.list-content {
  flex: 1;
}

.list-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.list-arrow {
  color: var(--text-muted);
  font-size: 32rpx;
}

/* 时间线样式 */
.timeline {
  position: relative;
  padding-left: 40rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: var(--border-color);
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-dot {
  position: absolute;
  left: -36rpx;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--primary-color);
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx var(--primary-color);
}

.timeline-dot.success {
  background: var(--success-color);
  box-shadow: 0 0 0 2rpx var(--success-color);
}

.timeline-dot.warning {
  background: var(--warning-color);
  box-shadow: 0 0 0 2rpx var(--warning-color);
}

.timeline-time {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.timeline-content {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 进度条 */
.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
  z-index: 999;
}

.fab-icon {
  font-size: 60rpx;
  color: #ffffff;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.photo-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
  background: #fafafa;
}

.photo-add-icon {
  font-size: 60rpx;
  color: #bfbfbf;
  margin-bottom: 8rpx;
}

.photo-add-text {
  font-size: 24rpx;
  color: #999999;
}

/* 水印样式 */
.watermark {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  right: 10rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 20rpx;
  padding: 8rpx;
  border-radius: 4rpx;
}

/* 评分星星 */
.stars {
  display: flex;
  align-items: center;
}

.star {
  font-size: 32rpx;
  color: #e8e8e8;
  margin-right: 8rpx;
}

.star.active {
  color: #faad14;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
