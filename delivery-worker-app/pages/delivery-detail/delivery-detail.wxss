/* pages/delivery-detail/delivery-detail.wxss */

/* 状态卡片 */
.status-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
}

.status-card.pending {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.status-card.progress {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.status-card.completed {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.status-info {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 订单规模卡片 */
.order-scale-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.order-scale-card.scale-large {
  background: #fff1f0;
  border: 2rpx solid #ffccc7;
}

.order-scale-card.scale-medium {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
}

.order-scale-card.scale-small {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
}

.scale-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.scale-info {
  flex: 1;
}

.scale-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.scale-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.scale-detail {
  text-align: right;
}

.scale-item {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

/* 超时人工判断卡片 */
.manual-timeout-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.timeout-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.timeout-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.timeout-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.timeout-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.timeout-status.pending {
  background: #fffbe6;
  color: #d48806;
}

.timeout-status.approved {
  background: #f6ffed;
  color: #52c41a;
}

.timeout-status.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.timeout-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.timeout-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.timeout-label {
  font-size: 28rpx;
  color: #666666;
}

.timeout-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.timeout-value.overtime {
  color: #ff4d4f;
}

.timeout-reason {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.reason-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
  display: block;
}

.reason-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.timeout-manager {
  font-size: 24rpx;
  color: #999999;
  text-align: right;
}

/* 临时工申请信息 */
.request-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.request-status.pending {
  background: #fffbe6;
  color: #d48806;
}

.request-status.approved {
  background: #f6ffed;
  color: #52c41a;
}

.request-status.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.temp-request-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.temp-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.list-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.temp-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.temp-avatar {
  width: 64rpx;
  height: 64rpx;
  background: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  margin-right: 16rpx;
}

.temp-info {
  flex: 1;
}

.temp-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.temp-phone {
  font-size: 24rpx;
  color: #999999;
}

.temp-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.temp-status.working {
  background: #e6f7ff;
  color: #1890ff;
}

.temp-status.checked {
  background: #f6ffed;
  color: #52c41a;
}

.apply-btn {
  width: 100%;
  height: 80rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
}

.apply-btn::after {
  border: none;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  word-break: break-all;
}

.info-value.with-action {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  font-size: 36rpx;
  padding: 8rpx;
}

/* 时间线 */
.timeline {
  position: relative;
  padding-left: 40rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 2rpx;
  background: #e8e8e8;
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -36rpx;
  top: 4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #e8e8e8;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx #e8e8e8;
}

.timeline-dot.completed {
  background: #52c41a;
  box-shadow: 0 0 0 2rpx #52c41a;
}

.timeline-dot.active {
  background: #1890ff;
  box-shadow: 0 0 0 2rpx #1890ff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.timeline-content {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.timeline-time {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.timeline-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.timeline-photos {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.timeline-photos image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

/* 货品表格 */
.goods-count {
  font-size: 26rpx;
  color: #999999;
}

.goods-table {
  margin-top: 10rpx;
}

.table-header {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.th-item {
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
}

.table-row {
  display: flex;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.td-item {
  font-size: 28rpx;
  color: #333333;
}

/* 问题列表 */
.problem-list {
  margin-top: 10rpx;
}

.problem-item {
  display: flex;
  background: #fff1f0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.problem-item:last-child {
  margin-bottom: 0;
}

.problem-icon {
  width: 64rpx;
  height: 64rpx;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.problem-content {
  flex: 1;
}

.problem-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.problem-type {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.problem-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.problem-status.pending {
  background: #fffbe6;
  color: #d48806;
}

.problem-status.resolved {
  background: #f6ffed;
  color: #52c41a;
}

.problem-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.problem-time {
  font-size: 24rpx;
  color: #999999;
}

/* 客户评价 */
.rating-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.rating-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #faad14;
  line-height: 1;
  margin-bottom: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 40rpx;
  color: #e8e8e8;
}

.star.active {
  color: #faad14;
}

.rating-comment {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  line-height: 1.6;
  font-style: italic;
}

/* 底部操作 */
.action-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666666;
}

.action-btn::after {
  border: none;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.header-right {
  display: flex;
  align-items: center;
}
