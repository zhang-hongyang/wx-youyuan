/* pages/checkin/checkin.wxss - 新打卡样式 */

.checkin-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 头部 */
.checkin-header {
  position: relative;
  height: 300rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
  color: #ffffff;
}

.type-icon-large {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.type-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.type-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 时间显示 */
.time-display {
  background: #ffffff;
  border-radius: 16rpx;
  margin: -60rpx 30rpx 20rpx;
  padding: 40rpx;
  text-align: center;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.current-time {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #1890ff;
  line-height: 1;
  margin-bottom: 16rpx;
}

.current-date {
  font-size: 28rpx;
  color: #666666;
}

/* 订单信息卡片 */
.order-info-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 30rpx;
  font-weight: 600;
  color: #1890ff;
}

.customer-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.order-address {
  font-size: 26rpx;
  color: #666666;
}

/* 定位卡片 */
.location-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.location-content {
  flex: 1;
}

.location-title {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.location-address {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.location-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.location-status.success {
  background: #f6ffed;
  color: #52c41a;
}

.location-status.warning {
  background: #fff1f0;
  color: #ff4d4f;
}

.refresh-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* 照片区域 */
.photo-section {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.required {
  color: #ff4d4f;
  margin-left: 8rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.photo-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-watermark {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx 12rpx;
}

.photo-watermark text {
  display: block;
  font-size: 18rpx;
  color: #ffffff;
  line-height: 1.4;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 77, 79, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
  background: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  color: #bfbfbf;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 26rpx;
  color: #666666;
}

.add-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 拍照提示 */
.photo-tips {
  display: flex;
  align-items: flex-start;
  background: #e6f7ff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 20rpx 30rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #1890ff;
  line-height: 1.6;
}

/* 备注 */
.remark-section {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.remark-section textarea {
  width: 100%;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 底部 */
.checkin-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.footer-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.validation-info {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ff4d4f;
}

.validation-icon {
  margin-right: 8rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}
