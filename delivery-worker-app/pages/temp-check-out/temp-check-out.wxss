/* pages/temp-check-out/temp-check-out.wxss */

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
}

.worker-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.worker-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.worker-detail {
  flex: 1;
}

.worker-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.worker-id {
  font-size: 24rpx;
  opacity: 0.8;
}

.work-duration {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
}

.duration-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.duration-value {
  font-size: 36rpx;
  font-weight: 700;
}

/* 时间显示 */
.time-display {
  text-align: center;
  padding: 40rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.time-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.time-value {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #1890ff;
  line-height: 1;
  margin-bottom: 12rpx;
}

.date-value {
  font-size: 28rpx;
  color: #666666;
}

/* 定位区域 */
.location-section {
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.location-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.location-address {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.location-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.location-status.verified {
  background: #f6ffed;
  color: #52c41a;
}

.location-status.pending {
  background: #fffbe6;
  color: #d48806;
}

.refresh-btn {
  width: 100%;
  height: 72rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-btn::after {
  border: none;
}

/* 工作确认 */
.work-confirm {
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333333;
}

.checkbox-item checkbox {
  margin-right: 16rpx;
}

/* 拍照区域 */
.photo-section {
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.photo-hint {
  background: #e6f7ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.photo-hint text {
  font-size: 26rpx;
  color: #1890ff;
  line-height: 1.5;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.photo-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-watermark {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  padding: 12rpx;
}

.photo-watermark text {
  display: block;
  font-size: 20rpx;
  color: #ffffff;
  line-height: 1.4;
}

.delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(255, 77, 79, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
  background: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 26rpx;
  color: #666666;
}

.add-hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 反馈区域 */
.feedback-section {
  padding: 30rpx 0;
}

.feedback-section textarea {
  width: 100%;
  height: 160rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 签字区域 */
.signature-section {
  padding: 30rpx 0;
  border-top: 2rpx solid #f0f0f0;
}

.signature-board {
  position: relative;
  height: 280rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.signature-canvas {
  width: 100%;
  height: 100%;
}

.signature-placeholder {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.signature-placeholder text {
  font-size: 30rpx;
  color: #cccccc;
}

.signature-actions {
  display: flex;
  gap: 20rpx;
}

.clear-btn, .save-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn {
  background: #f5f5f5;
  color: #666666;
}

.save-btn {
  background: #1890ff;
  color: #ffffff;
}

.clear-btn::after, .save-btn::after {
  border: none;
}

/* 结算卡片 */
.settlement-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.settlement-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.settlement-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.settlement-label {
  font-size: 28rpx;
  color: #666666;
}

.settlement-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.settlement-divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}

.settlement-row.total .settlement-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.settlement-row.total .settlement-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #faad14;
}

/* 提交按钮 */
.submit-btn {
  width: calc(100% - 40rpx);
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  margin: 40rpx 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}

/* 底部提示 */
.footer-tips {
  text-align: center;
  padding: 20rpx 40rpx 60rpx;
}

.footer-tips text {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.5;
}
