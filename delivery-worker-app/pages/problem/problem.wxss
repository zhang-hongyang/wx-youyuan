/* pages/problem/problem.wxss */

/* 问题类型选择 */
.problem-types {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-card.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.type-card.active .type-icon {
  background: #1890ff;
}

.type-name {
  font-size: 28rpx;
  color: #666666;
}

.type-card.active .type-name {
  color: #1890ff;
  font-weight: 500;
}

/* 子类型选择 */
.sub-types {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.sub-type {
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.sub-type.active {
  background: #e6f7ff;
  color: #1890ff;
  border-color: #1890ff;
}

/* 表单区域 */
.form-section {
  margin-top: 20rpx;
}

.form-row {
  margin-bottom: 24rpx;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-row input,
.form-row textarea {
  width: 100%;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-row textarea {
  height: 160rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-placeholder {
  color: #999999;
}

.arrow {
  color: #cccccc;
  font-size: 32rpx;
}

/* 严重程度选择 */
.severity-selector {
  display: flex;
  gap: 20rpx;
}

.severity-option {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666666;
}

.severity-option.active {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 复选框列表 */
.checkbox-list {
  margin-bottom: 24rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.checkbox-item:last-child {
  border-bottom: none;
}

.checkbox-label {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333333;
}

/* 紧急通知 */
.urgency-notice {
  display: flex;
  align-items: center;
  background: #fff1f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.urgency-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.urgency-text {
  flex: 1;
  font-size: 26rpx;
  color: #ff4d4f;
  line-height: 1.6;
}

/* 订单选择 */
.order-picker {
  min-height: 100rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
}

.order-no {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.order-customer {
  font-size: 26rpx;
  color: #999999;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.photo-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.photo-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 77, 79, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #d9d9d9;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #666666;
}

.add-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 补充说明 */
.remark-textarea {
  width: 100%;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 处理期望 */
.expect-options {
  display: flex;
  gap: 20rpx;
}

.expect-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.expect-option.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.option-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.option-text {
  font-size: 24rpx;
  color: #666666;
}

.expect-option.active .option-text {
  color: #1890ff;
}

/* 提交按钮 */
.submit-btn {
  width: calc(100% - 40rpx);
  height: 96rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  margin: 40rpx 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 79, 0.35);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

/* 历史记录 */
.history-section {
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.view-all {
  font-size: 26rpx;
  color: #1890ff;
}

.problem-list {
  margin-bottom: 40rpx;
}

.problem-item {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.problem-icon {
  width: 72rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.problem-content {
  flex: 1;
}

.problem-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.problem-type {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-tag.pending {
  background: #fffbe6;
  color: #d48806;
}

.status-tag.processing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-tag.resolved {
  background: #f6ffed;
  color: #52c41a;
}

.problem-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.problem-time {
  font-size: 24rpx;
  color: #999999;
}
