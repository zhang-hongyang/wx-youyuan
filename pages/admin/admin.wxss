/* pages/admin/admin.wxss */

.admin-container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 顶部 */
.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.date-display {
  font-size: 26rpx;
  color: #999999;
}

/* 概览卡片 */
.overview-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.overview-item {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  color: #ffffff;
}

.overview-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.overview-num.warning {
  color: #faad14;
}

.overview-label {
  font-size: 22rpx;
  opacity: 0.9;
}

/* 人员列表 */
.staff-list {
  margin-top: 10rpx;
}

.staff-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.staff-item:last-child {
  border-bottom: none;
}

.staff-avatar {
  width: 72rpx;
  height: 72rpx;
  background: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
  margin-right: 20rpx;
}

.staff-info {
  flex: 1;
}

.staff-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.staff-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 16rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-tag.working {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.resting {
  background: #f5f5f5;
  color: #999999;
}

.status-tag.warning {
  background: #fff1f0;
  color: #ff4d4f;
}

.staff-task, .staff-location {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
}

.staff-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
}

.action-icon::after {
  border: none;
}

/* 刷新按钮 */
.refresh-btn {
  font-size: 26rpx;
  color: #1890ff;
}

/* 异常列表 */
.alert-count {
  background: #ff4d4f;
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.alert-list {
  margin-top: 10rpx;
}

.alert-item {
  display: flex;
  padding: 24rpx;
  background: #fff1f0;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.alert-item:last-child {
  margin-bottom: 0;
}

.alert-item.warning {
  background: #fffbe6;
}

.alert-icon {
  width: 64rpx;
  height: 64rpx;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.alert-item.warning .alert-icon {
  background: #faad14;
}

.alert-content {
  flex: 1;
}

.alert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.alert-type {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.alert-time {
  font-size: 24rpx;
  color: #999999;
}

.alert-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.alert-staff {
  font-size: 24rpx;
  color: #999999;
}

.alert-actions {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.handle-btn {
  padding: 12rpx 30rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.handle-btn::after {
  border: none;
}

/* 排行 */
.period-picker {
  font-size: 26rpx;
  color: #1890ff;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ranking-list {
  margin-top: 10rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item.top3 .rank-num {
  background: #faad14;
  color: #ffffff;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
  font-weight: 600;
  margin-right: 20rpx;
}

.rank-info {
  flex: 1;
}

.rank-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.rank-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.rank-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff 0%, #096dd9 100%);
  border-radius: 6rpx;
}

.rank-score {
  text-align: right;
  margin-left: 20rpx;
}

.score-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.score-bonus {
  font-size: 24rpx;
  color: #faad14;
}

/* 指标网格 */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 10rpx;
}

.metric-item {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.metric-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.metric-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.metric-trend {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.metric-trend.up {
  background: #f6ffed;
  color: #52c41a;
}

.metric-trend.down {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-name {
  font-size: 24rpx;
  color: #666666;
}
