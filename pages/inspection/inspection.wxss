/* pages/inspection/inspection.wxss */

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  padding: 30rpx;
  padding-bottom: 20rpx;
}

/* 订单卡片 */
.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.order-card.expanded {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.order-info {
  flex: 1;
}

.order-no {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.order-customer {
  font-size: 26rpx;
  color: #666666;
}

.order-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.order-date {
  font-size: 24rpx;
  color: #999999;
}

.expand-icon {
  font-size: 28rpx;
  color: #999999;
}

/* 订单详情 */
.order-detail {
  padding: 0 30rpx 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin: 30rpx 0 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #1890ff;
}

/* 货物列表 */
.goods-list {
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item.header {
  background: #e6f7ff;
  font-weight: 600;
}

.goods-item.abnormal {
  background: #fff1f0;
}

.goods-name {
  flex: 2;
  font-size: 26rpx;
  color: #333333;
}

.goods-spec {
  flex: 1;
  font-size: 24rpx;
  color: #999999;
}

.goods-qty {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
}

.goods-qty.expected {
  color: #999999;
}

.goods-qty.actual input {
  width: 80rpx;
  height: 56rpx;
  background: #ffffff;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 物资核对 */
.inventory-check {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.check-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.check-item:last-child {
  border-bottom: none;
}

.check-label {
  font-size: 28rpx;
  color: #333333;
}

.check-control {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.check-expected {
  font-size: 24rpx;
  color: #999999;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.qty-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1890ff;
  min-width: 60rpx;
  text-align: center;
}

/* 损坏登记 */
.damage-section {
  background: #fff1f0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.damage-list {
  margin-bottom: 20rpx;
}

.damage-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.damage-info {
  flex: 1;
}

.damage-goods {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.damage-count {
  font-size: 24rpx;
  color: #999999;
}

.damage-type {
  margin-right: 20rpx;
}

.picker-value {
  font-size: 26rpx;
  color: #1890ff;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.damage-action {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 40rpx;
  color: #ff4d4f;
}

.add-damage-btn {
  width: 100%;
  height: 80rpx;
  background: #ff4d4f;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-damage-btn::after {
  border: none;
}

/* 汇总 */
.summary-section {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
}

.summary-value.missing {
  color: #faad14;
}

.summary-value.scrap {
  color: #ff4d4f;
}

.summary-value.repair {
  color: #1890ff;
}

.summary-value.normal {
  color: #52c41a;
}

/* 备注 */
.remark-section textarea {
  width: 100%;
  height: 120rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-save, .btn-submit {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-save {
  background: #f5f5f5;
  color: #666666;
}

.btn-submit {
  background: #1890ff;
  color: #ffffff;
}

.btn-save::after, .btn-submit::after {
  border: none;
}

/* 历史记录 */
.history-list {
  padding: 0 20rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.history-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.history-no {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.history-date {
  font-size: 24rpx;
  color: #999999;
}

.history-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.stat-item.missing {
  background: #fffbe6;
  color: #d48806;
}

.stat-item.scrap {
  background: #fff1f0;
  color: #ff4d4f;
}

.stat-item.repair {
  background: #e6f7ff;
  color: #1890ff;
}

.stat-item.normal {
  background: #f6ffed;
  color: #52c41a;
}

.history-staff {
  font-size: 26rpx;
  color: #666666;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  background: #ffffff;
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 85%;
  max-height: 80%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: relative;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  position: absolute;
  right: 30rpx;
  font-size: 48rpx;
  color: #999999;
}

.modal-body {
  padding: 30rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.type-options {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.type-option.selected {
  background: #e6f7ff;
  border-color: #1890ff;
}

.type-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.type-option.selected .type-name {
  color: #1890ff;
}

.type-desc {
  font-size: 24rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.btn-secondary, .btn-primary {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666666;
}

.btn-primary {
  background: #1890ff;
  color: #ffffff;
}

.btn-secondary::after, .btn-primary::after {
  border: none;
}
