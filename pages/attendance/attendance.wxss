/* pages/attendance/attendance.wxss - 新考勤样式 */

/* 日期选择器 */
.date-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.date-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #1890ff;
  font-weight: 300;
}

.date-arrow.disabled {
  color: #cccccc;
}

.current-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 40rpx;
}

.date-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.week-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
}

.overall-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  text-align: center;
}

.stats-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 打卡记录列表 */
.checkin-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.checkin-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.type-icon.work {
  background: #e6f7ff;
}

.type-info {
  display: flex;
  flex-direction: column;
}

.type-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.type-time {
  font-size: 24rpx;
  color: #999999;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-time {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.record-status.normal {
  background: #f6ffed;
  color: #52c41a;
}

.record-status.late {
  background: #fff1f0;
  color: #ff4d4f;
}

.mini-btn {
  padding: 16rpx 40rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.mini-btn::after {
  border: none;
}

.checkin-item.completed .type-name {
  color: #52c41a;
}

/* 订单打卡记录 */
.order-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  padding: 30rpx 0 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.order-checkin-item {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-info {
  margin-bottom: 20rpx;
}

.order-no {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.customer-name {
  font-size: 26rpx;
  color: #666666;
}

.checkin-flow {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #e8e8e8;
  margin-bottom: 12rpx;
}

.flow-step.completed .step-dot {
  background: #52c41a;
}

.step-name {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.flow-step.completed .step-name {
  color: #52c41a;
  font-weight: 500;
}

.step-time {
  font-size: 22rpx;
  color: #999999;
}

.flow-line {
  flex: 1;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 20rpx;
  margin-bottom: 40rpx;
}

.flow-line.completed {
  background: #52c41a;
}

/* 空状态 */
.empty-checkins {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 周历 */
.week-calendar {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}

.week-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  min-width: 80rpx;
}

.week-day.today {
  background: #e6f7ff;
}

.week-day.checked {
  background: #f6ffed;
}

.day-name {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.day-num {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.day-status {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e8e8e8;
}

.day-status.checked {
  background: #52c41a;
}

.week-day.today .day-num {
  color: #1890ff;
}

/* 说明卡片 */
.notice-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.notice-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.dot.normal {
  background: #1890ff;
}
