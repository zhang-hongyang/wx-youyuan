/* pages/tracking/tracking.wxss */

.tracking-container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 地图区域 */
.map-container {
  position: relative;
  height: 600rpx;
}

.delivery-map {
  width: 100%;
  height: 100%;
}

/* 地图控制按钮 */
.map-controls {
  position: absolute;
  right: 30rpx;
  bottom: 180rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.control-icon {
  font-size: 40rpx;
}

/* 预计到达卡片 */
.eta-card {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.eta-icon {
  width: 80rpx;
  height: 80rpx;
  background: #e6f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
}

.eta-info {
  flex: 1;
}

.eta-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.eta-time {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1890ff;
}

.eta-distance {
  text-align: right;
}

.distance-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.distance-label {
  font-size: 24rpx;
  color: #999999;
}

/* 信息卡片 */
.info-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: -40rpx 20rpx 20rpx;
  padding: 30rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 司机信息 */
.driver-info {
  display: flex;
  align-items: center;
}

.driver-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #ffffff;
  margin-right: 24rpx;
}

.driver-detail {
  flex: 1;
}

.driver-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.driver-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
}

.driver-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 8rpx;
}

.driver-phone {
  font-size: 28rpx;
  color: #1890ff;
}

.driver-rating {
  text-align: right;
}

.rating-score {
  display: block;
  font-size: 30rpx;
  color: #faad14;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.rating-count {
  font-size: 24rpx;
  color: #999999;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 30rpx 0;
}

/* 订单信息 */
.order-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  word-break: break-all;
}

/* 进度卡片 */
.progress-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 30rpx;
}

.progress-timeline {
  position: relative;
  padding-left: 40rpx;
}

.progress-timeline::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 4rpx;
  background: #e8e8e8;
}

.progress-item {
  position: relative;
  padding-bottom: 40rpx;
  display: flex;
  align-items: flex-start;
}

.progress-item:last-child {
  padding-bottom: 0;
}

.progress-dot {
  position: absolute;
  left: -36rpx;
  top: 4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #e8e8e8;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 4rpx #e8e8e8;
}

.progress-item.completed .progress-dot {
  background: #52c41a;
  box-shadow: 0 0 0 4rpx #52c41a;
}

.progress-item.active .progress-dot {
  background: #1890ff;
  box-shadow: 0 0 0 4rpx #1890ff;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.progress-content {
  flex: 1;
}

.progress-status {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.progress-item.completed .progress-status {
  color: #52c41a;
}

.progress-item.active .progress-status {
  color: #1890ff;
}

.progress-time {
  font-size: 26rpx;
  color: #999999;
}

/* 刷新提示 */
.refresh-hint {
  text-align: center;
  padding: 20rpx;
}

.refresh-hint text {
  font-size: 24rpx;
  color: #999999;
}

/* 操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx 40rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.share-btn {
  flex: 1;
  height: 90rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border-radius: 45rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-btn::after {
  border: none;
}

.btn-icon {
  margin-right: 12rpx;
}

.stop-btn {
  width: 200rpx;
  height: 90rpx;
  background: #f5f5f5;
  color: #666666;
  border-radius: 45rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stop-btn::after {
  border: none;
}
