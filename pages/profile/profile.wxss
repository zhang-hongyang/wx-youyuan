/* pages/profile/profile.wxss */

/* 用户卡片 */
.user-card {
  position: relative;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 0 0 40rpx 40rpx;
  padding: 60rpx 40rpx 80rpx;
  margin: -20rpx -20rpx 0;
  overflow: hidden;
}

.user-bg {
  position: absolute;
  top: -30%;
  right: -10%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-content {
  position: relative;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 60rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-right: 16rpx;
}

.user-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.user-tag.formal {
  background: rgba(82, 196, 26, 0.3);
  border: 2rpx solid rgba(82, 196, 26, 0.5);
  color: #ffffff;
}

.user-tag.temp {
  background: rgba(250, 173, 20, 0.3);
  border: 2rpx solid rgba(250, 173, 20, 0.5);
  color: #ffffff;
}

.user-id {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.user-skills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
  color: #ffffff;
}

/* 快捷数据 */
.stats-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  margin: -40rpx 20rpx 20rpx;
  padding: 30rpx 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* 菜单卡片 */
.menu-card {
  margin-top: 20rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f8f8;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-icon.performance {
  background: #e6f7ff;
}

.menu-icon.bonus {
  background: #fffbe6;
}

.menu-icon.attendance {
  background: #f6ffed;
}

.menu-icon.problem {
  background: #fff1f0;
}

.menu-icon.appeal {
  background: #f9f0ff;
}

.menu-icon.settings {
  background: #f5f5f5;
}

.menu-icon.support {
  background: #e6f7ff;
}

.menu-icon.about {
  background: #f5f5f5;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-badge {
  background: #ff4d4f;
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

/* 临时工提示 */
.temp-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fffbe6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #d48806;
}

/* 退出登录 */
.logout-btn {
  width: calc(100% - 40rpx);
  height: 90rpx;
  background: #ffffff;
  color: #ff4d4f;
  border-radius: 45rpx;
  font-size: 32rpx;
  margin: 40rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 20rpx 0 40rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #cccccc;
}
