/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* 头部背景 */
.login-header {
  position: relative;
  height: 400rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 0 0 60rpx 60rpx;
  overflow: hidden;
}

.wave {
  position: absolute;
  bottom: -50rpx;
  left: -50%;
  width: 200%;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  animation: wave 8s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

.logo-section {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录主体 */
.login-body {
  flex: 1;
  padding: 40rpx 50rpx;
}

.login-card,
.bind-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx;
  box-shadow: 0 18rpx 48rpx rgba(9, 109, 217, 0.08);
  margin-bottom: 32rpx;
}

.login-card-title,
.bind-card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 16rpx;
}

.login-card-desc,
.bind-card-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.wechat-tips {
  background: #f6fbff;
  border: 2rpx solid #d6ecff;
  border-radius: 20rpx;
  padding: 24rpx 26rpx;
  margin-top: 28rpx;
}

.tip-row {
  font-size: 26rpx;
  line-height: 1.8;
  color: #245b8e;
}

.bind-openid {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #fafafa;
}

/* 表单 */
.login-form {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-item input {
  width: 100%;
  height: 90rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-item input:focus {
  background: #ffffff;
  border-color: #1890ff;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

.submit-btn::after,
.secondary-btn::after {
  border: none;
}

.bind-actions {
  margin-top: 24rpx;
}

.secondary-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f3f7fb;
  color: #245b8e;
  font-size: 30rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #d9d9d9;
  box-shadow: none;
}

/* 底部 */
.login-footer {
  padding: 40rpx 50rpx 60rpx;
  text-align: center;
}

.agreement-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
}

.link {
  color: #1890ff;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 85%;
  max-height: 80%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: relative;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  position: absolute;
  right: 30rpx;
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 40rpx;
  max-height: 600rpx;
}

.agreement-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.modal-footer {
  padding: 30rpx 40rpx;
  border-top: 2rpx solid #f0f0f0;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  background: #1890ff;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn::after {
  border: none;
}
