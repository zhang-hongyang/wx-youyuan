<!--pages/delivery-detail/delivery-detail.wxml-->
<view class="container">
  <!-- 单据状态卡片 -->
  <view class="status-card {{task.status}}">
    <view class="status-icon">{{task.statusIcon}}</view>
    <view class="status-info">
      <text class="status-text">{{task.statusText}}</text>
      <text class="status-desc">{{task.statusDesc}}</text>
    </view>
  </view>

  <!-- 订单规模标识 -->
  <view class="order-scale-card scale-{{task.scale}}" wx:if="{{task.scale}}">
    <view class="scale-icon">{{task.scale === 'large' ? '🔴' : (task.scale === 'medium' ? '🟡' : '🟢')}}</view>
    <view class="scale-info">
      <text class="scale-label">订单规模</text>
      <text class="scale-name">{{task.scaleName}}</text>
    </view>
    <view class="scale-detail">
      <text class="scale-item">货物{{task.goodsCount}}件</text>
      <text class="scale-item">预计{{task.estimatedHours}}小时</text>
    </view>
  </view>

  <!-- 超时人工判断提示 -->
  <view class="manual-timeout-card" wx:if="{{task.status === 'completed' && task.timeoutReviewStatus}}">
    <view class="timeout-header">
      <text class="timeout-icon">⏱️</text>
      <text class="timeout-title">超时判定</text>
      <view class="timeout-status {{task.timeoutReviewStatus}}">
        {{task.timeoutReviewStatus === 'pending' ? '待审核' : (task.timeoutReviewStatus === 'approved' ? '已通过' : '已驳回')}}
      </view>
    </view>
    <view class="timeout-content">
      <view class="timeout-row">
        <text class="timeout-label">实际用时</text>
        <text class="timeout-value {{task.isOvertime ? 'overtime' : ''}}">{{task.actualHours}}小时</text>
      </view>
      <view class="timeout-row">
        <text class="timeout-label">预计用时</text>
        <text class="timeout-value">{{task.estimatedHours}}小时</text>
      </view>
      <view class="timeout-reason" wx:if="{{task.timeoutReason}}">
        <text class="reason-label">超时原因：</text>
        <text class="reason-text">{{task.timeoutReason}}</text>
      </view>
      <view class="timeout-manager" wx:if="{{task.timeoutReviewStatus !== 'pending'}}">
        <text>审核人：{{task.timeoutReviewer}} · {{task.timeoutReviewTime}}</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">📋</text>
        <text class="card-title">基本信息</text>
      </view>
    </view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">送货单号</text>
        <text class="info-value">{{task.orderNo}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">客户名称</text>
        <text class="info-value">{{task.customerName}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">联系电话</text>
        <view class="info-value with-action">
          <text>{{task.customerPhone}}</text>
          <text class="action-btn" bindtap="callCustomer">📞</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-label">送货地址</text>
        <view class="info-value with-action">
          <text>{{task.address}}</text>
          <text class="action-btn" bindtap="navigateToAddress">🧭</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-label">预约时间</text>
        <text class="info-value">{{task.scheduledTime}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">配送货物</text>
        <text class="info-value">{{task.goodsCount}}件</text>
      </view>
    </view>
  </view>

  <!-- 临时工申请信息 -->
  <view class="card" wx:if="{{tempWorkerRequest}}">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">👥</text>
        <text class="card-title">临时工配合</text>
      </view>
      <view class="header-right">
        <view class="request-status {{tempWorkerRequest.status}}">
          {{tempWorkerRequest.statusText}}
        </view>
      </view>
    </view>
    <view class="temp-request-info">
      <view class="info-row">
        <text class="info-label">申请人数</text>
        <text class="info-value">{{tempWorkerRequest.count}}人</text>
      </view>
      <view class="info-row">
        <text class="info-label">工作时长</text>
        <text class="info-value">{{tempWorkerRequest.hours}}小时</text>
      </view>
      <view class="info-row" wx:if="{{tempWorkerRequest.reason}}">
        <text class="info-label">申请原因</text>
        <text class="info-value">{{tempWorkerRequest.reason}}</text>
      </view>
      <view class="temp-list" wx:if="{{tempWorkerRequest.workers.length > 0}}">
        <text class="list-title">已安排临时工</text>
        <view class="temp-item" wx:for="{{tempWorkerRequest.workers}}" wx:key="id">
          <view class="temp-avatar">{{item.name[0]}}</view>
          <view class="temp-info">
            <text class="temp-name">{{item.name}}</text>
            <text class="temp-phone">{{item.phone}}</text>
          </view>
          <view class="temp-status {{item.checkedOut ? 'checked' : 'working'}}">
            {{item.checkedOut ? '已下班' : '工作中'}}
          </view>
        </view>
      </view>
      <button class="apply-btn" bindtap="applyTempWorker" wx:if="{{task.status !== 'completed' && !tempWorkerRequest}}">
        申请临时工
      </button>
    </view>
  </view>

  <!-- 时间线 -->
  <view class="card">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">⏱️</text>
        <text class="card-title">执行时间线</text>
      </view>
    </view>
    <view class="timeline">
      <view class="timeline-item {{item.completed ? 'completed' : ''}} {{item.active ? 'active' : ''}}" 
            wx:for="{{timeline}}" 
            wx:key="type">
        <view class="timeline-dot {{item.status}}"></view>
        <view class="timeline-content">
          <view class="timeline-header">
            <text class="timeline-title">{{item.title}}</text>
            <text class="timeline-time" wx:if="{{item.time}}">{{item.time}}</text>
          </view>
          <text class="timeline-desc">{{item.desc}}</text>
          <view class="timeline-photos" wx:if="{{item.photos && item.photos.length > 0}}">
            <image wx:for="{{item.photos}}" 
                   wx:for-item="photo" 
                   wx:key="*this" 
                   src="{{photo}}" 
                   mode="aspectFill"
                   bindtap="previewPhoto"
                   data-photos="{{item.photos}}"
                   data-current="{{photo}}"/>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 货品清单 -->
  <view class="card">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">📦</text>
        <text class="card-title">货品清单</text>
      </view>
      <view class="header-right">
        <text class="goods-count">共{{goodsList.length}}项</text>
      </view>
    </view>
    <view class="goods-table">
      <view class="table-header">
        <text class="th-item" style="flex: 2;">物品名称</text>
        <text class="th-item" style="flex: 1;">规格</text>
        <text class="th-item" style="flex: 1; text-align: right;">数量</text>
      </view>
      <view class="table-row" wx:for="{{goodsList}}" wx:key="id">
        <text class="td-item" style="flex: 2;">{{item.name}}</text>
        <text class="td-item" style="flex: 1; color: #999;">{{item.spec}}</text>
        <text class="td-item" style="flex: 1; text-align: right; font-weight: 500;">×{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 问题记录 -->
  <view class="card" wx:if="{{problems.length > 0}}">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">⚠️</text>
        <text class="card-title">问题记录</text>
      </view>
    </view>
    <view class="problem-list">
      <view class="problem-item" wx:for="{{problems}}" wx:key="id">
        <view class="problem-icon">{{item.icon}}</view>
        <view class="problem-content">
          <view class="problem-header">
            <text class="problem-type">{{item.type}}</text>
            <view class="problem-status {{item.status}}">{{item.statusText}}</view>
          </view>
          <text class="problem-desc">{{item.description}}</text>
          <text class="problem-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 客户评价 -->
  <view class="card" wx:if="{{task.status === 'completed' && rating}}">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">⭐</text>
        <text class="card-title">客户评价</text>
      </view>
    </view>
    <view class="rating-content">
      <view class="rating-score">
        <text class="score-num">{{rating.score}}</text>
        <view class="rating-stars">
          <text class="star {{index < rating.score ? 'active' : ''}}" wx:for="[1,2,3,4,5]" wx:key="index">★</text>
        </view>
      </view>
      <text class="rating-comment" wx:if="{{rating.comment}}">{{rating.comment}}</text>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="action-footer" wx:if="{{task.status !== 'completed'}}">
    <view class="action-btns">
      <button class="action-btn secondary" bindtap="reportProblem">上报问题</button>
      <button class="action-btn secondary" bindtap="goToTracking">行程共享</button>
      <block wx:if="{{!task.hasArriveCheckIn}}">
        <button class="action-btn primary" bindtap="goToArriveCheckIn">到达打卡</button>
      </block>
      <block wx:elif="{{!task.hasCompleteCheckIn}}">
        <button class="action-btn primary" bindtap="goToCompleteCheckIn">完工打卡</button>
      </block>
    </view>
    <view class="safe-area-bottom"></view>
  </view>
</view>
